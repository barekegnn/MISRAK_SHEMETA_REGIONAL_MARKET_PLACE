NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
GEMINI_API_KEY=

# Chapa TEST mode: dashboard → Test toggle ON → Settings → API Keys → Secret (e.g. CHASECK_TEST-...)
# Docs: https://developer.chapa.co/integrations/test-mode-vs-live-mode
CHAPA_SECRET_KEY=CHASECK_TEST-your-test-secret-here
CHAPA_CALLBACK_URL=
CHAPA_WEBHOOK_SECRET=

NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_DEMO_MODE=true

# Optional overrides for `npm run seed` Gmail-shaped testers (each role has its own default password)
